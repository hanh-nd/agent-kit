{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "kit-init",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/kit-init.js\"",
            "description": "Initialize Agent-Kit",
            "timeout": 10000
          },
          {
            "name": "inject-instructions",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/inject-agent-instructions.js\"",
            "description": "Inject agent instructions at session start",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "name": "inject-instructions",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/inject-agent-instructions.js\"",
            "description": "Inject agent instructions after /clear",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeModel": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "security-blocker",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/security-privacy.js\"",
            "description": "Hard-block access to sensitive files",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "kit-wiki-inbox",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/wiki-inbox-append.js\"",
            "description": "Log kit_save_handoff calls to wiki inbox",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "security-blocker",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/security-privacy.js\"",
            "description": "Hard-block access to sensitive files",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "export-history",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/export-conversation-history.js\"",
            "description": "Export transcript to wiki before /compact",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "export-history",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/export-conversation-history.js\"",
            "description": "Export transcript to wiki on session exit",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
