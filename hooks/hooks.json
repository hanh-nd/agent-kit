{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "kit-init",
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/hooks/session-start.js",
            "description": "Initialize Agent-Kit",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
